# .env.example
# Get your Gemini API key at https://aistudio.google.com/app/apikey
# Get your Google Maps API key at https://console.cloud.google.com/
# For Vite projects the variables must be prefixed with VITE_ to be available
# in client-side code. Copy this file to `.env` and fill in real values.

VITE_GEMINI_API_KEY=your_actual_gemini_api_key_here_replace_with_real_key
VITE_GOOGLE_MAPS_API_KEY=your_actual_google_maps_api_key_here_replace_with_real_key
JWT_SECRET=your_jwt_secret_here_change_in_production

# Frontend URL for CORS configuration (optional, defaults to http://localhost:5173)
FRONTEND_URL=http://localhost:5173

# Admin credentials for testing (DEV ONLY — change in production)
ADMIN_ALIAS=admin
ADMIN_PASSKEY=your_secure_admin_passkey_here
